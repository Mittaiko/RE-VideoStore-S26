@startuml VideoStore_Final

skinparam classAttributeIconSize 0

abstract class Price {
  + {abstract} get_price_code(): int
}

class RegularPrice {
  + get_price_code(): int
}

class NewReleasePrice {
  + get_price_code(): int
}

class ChildrensPrice {
  + get_price_code(): int
}

class Movie {
  + {static} REGULAR: int = 0
  + {static} NEW_RELEASE: int = 1
  + {static} CHILDRENS: int = 2
  - _title: str
  - _price_code: Price
  - _PRICE_MAP: dict
  + __init__(title: str, price_code: int)
  + get_title(): str
  + get_price_code(): int
  + set_price_code(new_price_code: int): void
  + get_charge(days_rented: int): float
}

class Rental {
  - _movie: Movie
  - _days: int
  + __init__(movie: Movie, days_rented: int)
  + get_days_rented(): int
  + get_movie(): Movie
  + get_charge(): float
  + get_frequent_renter_points(): int
}

class Customer {
  - name: str
  - rentals: List[Rental]
  + __init__(name: str)
  + get_name(): str
  + add_rental(rental: Rental): void
  + statement(): str
  - __get_total_charge(): float
}

Price <|-- RegularPrice
Price <|-- NewReleasePrice
Price <|-- ChildrensPrice

Movie "1" *-- "1" Price : has >
Customer "1" o-- "0..*" Rental : has >
Rental "1" --> "1" Movie : references >

@enduml
